# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Live room transport ────────────────────────────────────────────────────────
# Set to "true" to use Supabase Realtime for multiplayer rooms.
# Leave as "false" (or unset) to use the in-memory LocalRoomTransport (single device).
NEXT_PUBLIC_USE_SUPABASE_ROOMS=false

# ── Auth (optional) ───────────────────────────────────────────────────────────
# Required if you enable Supabase Auth for user accounts.
# NEXT_PUBLIC_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
